# ---------------------------------------------------------------------------
# Build Your Project Presentation — Backend environment configuration.
# Copy this file to ".env" and adjust values. NEVER commit a real .env.
# Validated once at startup; the app refuses to boot on missing/invalid values.
#
# These defaults are LOCAL-DEVELOPMENT ONLY and let `docker compose up` work
# out of the box. Change every credential before any shared/public environment.
#
# Host vs container: the values below assume you run the backend ON THE HOST
# (e.g. `npm run start:dev`) against the Compose-provided PostgreSQL/MinIO, so
# they use `localhost`. When the backend runs INSIDE Compose, docker-compose.yml
# overrides DATABASE_URL and MINIO_ENDPOINT to the service names `postgres` and
# `minio`. MINIO_PUBLIC_URL stays a host URL in both cases (the browser opens it).
# ---------------------------------------------------------------------------

# --- App / server ---
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# --- API docs (Swagger) ---
# UI served at http://localhost:3000/<SWAGGER_PATH>
SWAGGER_PATH=docs

# --- CORS / frontend origin ---
FRONTEND_ORIGIN=*

# --- Database (PostgreSQL) ---
# DATABASE_URL is what the app reads. Keep it consistent with the POSTGRES_*
# provisioning values below. Inside Compose the host is rewritten to `postgres`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/svoya_igra

# Docker Compose provisioning for the postgres service (not read by the app).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=svoya_igra
POSTGRES_PORT=5432

# --- MinIO / S3 storage ---
# MINIO_ENDPOINT is the host the backend connects to (overridden to `minio`
# inside Compose). MINIO_ACCESS_KEY/SECRET_KEY also become the MinIO root
# credentials for the local container (see docker-compose.yml).
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=svoya-igra
# Browser-facing base URL for public object links — stays a host URL.
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_USE_SSL=false
MINIO_PATH_STYLE=true

# --- WebSocket transport ---
WS_PATH=/socket.io
WS_CORS_ORIGIN=*

# --- File limits / presentation ---
MAX_FILE_SIZE_MB=25
ALLOWED_PRESENTATION_FORMATS=pdf,ppt,pptx
LATE_PENALTY=1

# --- Timers (seconds) ---
ANSWER_TIMER_SECONDS=60
SHOP_TIMER_SECONDS=120
PRESENTATION_PREP_SECONDS=600

# --- Game limits ---
MAX_TEAMS=3
MIN_TEAMS_TO_START=2
MAX_PLAYERS_PER_TEAM=5

# --- Reconnect / token settings ---
ROOM_CODE_LENGTH=6
RECONNECT_TOKEN_TTL_SECONDS=86400
